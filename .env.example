# Server Configuration
PORT=3000
NODE_ENV=production

# Domain Configuration (update before deployment)
DOMAIN=iggrabber.com
DOMAIN_URL=https://iggrabber.com

# Security
ENABLE_CORS=true
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info

# Rate Limiting (optional)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_ENABLED=true
CACHE_TTL=3600

# Features
ALLOW_VIDEO_DOWNLOAD=true
ALLOW_AUDIO_ONLY=false
MAX_VIDEO_DURATION_SECONDS=3600

# Analytics (optional)
ANALYTICS_ENABLED=false
GOOGLE_ANALYTICS_ID=
